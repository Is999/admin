-- 代码资产：管理员日志冷热查询子查询模板，用于按热表和历史表拼接统一检索。
-- SQL 方言：MySQL
-- 调用方：internal/jobs/archive.buildAdminLogUnionQuery；go:embed 加载后由 embedasset 剥离本说明再执行。
-- 参数来源：表名、列名来自归档配置白名单和标识符转义，trace/user/action/时间过滤值通过参数绑定传入。
-- 安全边界：仅生成单表 SELECT 子句，不接收任意 SQL；时间窗口、排序和分页由调用方统一限制。
SELECT {{.SelectColumns}}
FROM {{.TableName}}
WHERE 1 = 1{{if .HasTraceID}}
  AND trace_id = ?{{end}}{{if .HasUserID}}
  AND user_id = ?{{end}}{{if .HasUserName}}
  AND user_name = ?{{end}}{{if .HasAction}}
  AND action = ?{{end}}{{if .HasStartTime}}
  AND created_at >= ?{{end}}{{if .HasEndTime}}
  AND created_at <= ?{{end}}{{if .HasLowerBound}}
  AND created_at >= ?{{end}}{{if .HasUpperBound}}
  AND created_at < ?{{end}}
